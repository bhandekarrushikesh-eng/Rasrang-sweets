let cart=[];
let orderCounter=1;

function showCategory(category){
document.querySelectorAll('nav button').forEach(btn=>btn.classList.remove('active'));
event.target.classList.add('active');
const container=document.getElementById('menu');
container.innerHTML='';
menuData[category].forEach((item,i)=>{
const div=document.createElement('div');
div.className='item';
div.innerHTML=`
<img src="${item.img}" alt="${item.name}">
<div class="item-details">
<h3>${item.name}</h3>
<p>${item.desc}</p>
<span>₹${item.price}</span>
</div>
<div class="item-actions">
<input type="number" min="1" value="1" id="qty-${category}-${i}">
<button onclick="addToCart('${category}',${i})">Add</button>
</div>
`;
container.appendChild(div);
});
}

function addToCart(category,index){
const qty=parseInt(document.getElementById(`qty-${category}-${index}`).value);
const item=menuData[category][index];
const existing=cart.find(c=>c.name===item.name);
if(existing){ existing.qty+=qty; } else { cart.push({name:item.name,price:item.price,qty:qty}); }
updateCart();
alert(`${item.name} added to cart`);
}

function updateCart(){
document.getElementById('cart').innerText=`Cart (${cart.reduce((a,b)=>a+b.qty,0)})`;
}

document.getElementById('cart').addEventListener('click',()=>{ openCart(); });

function openCart(){
const cartItems=document.getElementById('cartItems');
cartItems.innerHTML='';
let total=0;
cart.forEach(item=>{
const li=document.createElement('li');
li.innerHTML=`${item.name} x ${item.qty} = ₹${item.qty*item.price} <button onclick="removeItem('${item.name}')">Remove</button>`;
cartItems.appendChild(li);
total+=item.qty*item.price;
});
document.getElementById('totalPrice').innerText=total;
document.getElementById('cartModal').style.display='flex';
}

function closeCart(){ document.getElementById('cartModal').style.display='none'; }

function removeItem(name){ cart=cart.filter(c=>c.name!==name); openCart(); updateCart(); }

function placeOrder(){
const name=document.getElementById('customerName').value;
const phone=document.getElementById('customerPhone').value;
const address=document.getElementById('customerAddress').value;
if(!name||!phone||!address){ alert('Please fill all details'); return; }
let total=0;
let orderText=`Rasrang Sweets Order\nOrder ID: #${orderCounter}\n\nItems:\n`;
cart.forEach(i=>{ orderText+=`${i.name} x ${i.qty} = ₹${i.qty*i.price}\n`; total+=i.qty*i.price; });
orderText+=`\nTotal: ₹${total}\n\nCustomer: ${name}\nPhone: ${phone}\nAddress: ${address}`;
window.open(`https://wa.me/918956433301?text=${encodeURIComponent(orderText)}`);
orderCounter++;
cart=[]; updateCart(); closeCart();
}

showCategory('Sweets');
</script>

